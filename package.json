{
  "name": "website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:dist": "node --experimental-strip-types scripts/audit-built-site.ts",
    "lint": "pnpm lint:code && pnpm lint:markdown && pnpm lint:css",
    "lint:code": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write . && markdownlint-cli2 --fix && stylelint \"src/**/*.css\" --fix",
    "format:check": "prettier --check . && markdownlint-cli2 && stylelint \"src/**/*.css\"",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "dictionary:audit": "node --experimental-strip-types scripts/dictionary-terms.ts"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.6",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-satteri": "^0.3.3",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "beautiful-mermaid": "^1.1.3",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "starlight-links-validator": "^0.25.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.8"
  }
}
